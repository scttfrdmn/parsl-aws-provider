[run]
source = parsl_ephemeral_aws
omit =
    */tests/*
    */templates/*
    */setup.py
    */__init__.py
    */venv/*
    */.venv/*
    */.eggs/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    raise ImportError
    except ImportError
    # Exclude mocking-specific code from coverage
    if not MOTO_AVAILABLE:
    if not LOCALSTACK_AVAILABLE:
    def mock_decorator

[html]
directory = coverage_html_report
title = Parsl Ephemeral AWS Provider Coverage Report

